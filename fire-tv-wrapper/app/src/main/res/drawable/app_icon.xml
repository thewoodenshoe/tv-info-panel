<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <gradient
                android:angle="315"
                android:endColor="#1D4ED8"
                android:startColor="#020617" />
        </shape>
    </item>
    <item
        android:bottom="16dp"
        android:left="16dp"
        android:right="16dp"
        android:top="16dp">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="#0F172A" />
            <stroke
                android:width="2dp"
                android:color="#38BDF8" />
        </shape>
    </item>
    <item
        android:bottom="34dp"
        android:left="34dp"
        android:right="34dp"
        android:top="34dp">
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <solid android:color="#22C55E" />
        </shape>
    </item>
</layer-list>
