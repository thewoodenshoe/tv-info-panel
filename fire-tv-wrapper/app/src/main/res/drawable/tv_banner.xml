<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:endColor="#020617"
                android:startColor="#1E3A8A" />
        </shape>
    </item>
    <item
        android:bottom="24dp"
        android:left="24dp"
        android:right="24dp"
        android:top="24dp">
        <shape android:shape="rectangle">
            <corners android:radius="18dp" />
            <solid android:color="#101B33" />
            <stroke
                android:width="2dp"
                android:color="#38BDF8" />
        </shape>
    </item>
    <item
        android:bottom="44dp"
        android:left="44dp"
        android:right="44dp"
        android:top="44dp">
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <solid android:color="#1E293B" />
            <stroke
                android:width="2dp"
                android:color="#22C55E" />
        </shape>
    </item>
</layer-list>
